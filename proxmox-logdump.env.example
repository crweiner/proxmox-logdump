# Required
PROXMOX_LOGDUMP_TOKEN=replace-with-your-shared-token
PROXMOX_LOGDUMP_RELAY_BASE_URL=http://relay-host-or-ip:1880

# Optional
# PROXMOX_LOGDUMP_STATE_DIR=/var/lib/proxmox-logdump
# PROXMOX_LOGDUMP_LIMIT=200
# PROXMOX_LOGDUMP_COMMAND_TIMEOUT=45
# PROXMOX_LOGDUMP_PVE_UPLOAD_URL=http://relay-host-or-ip:1880/ingest/tasklog/pve
# PROXMOX_LOGDUMP_PBS_UPLOAD_URL=http://relay-host-or-ip:1880/ingest/tasklog/pbs
